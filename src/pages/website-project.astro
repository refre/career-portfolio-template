---
import { Icon } from 'astro-icon/components';
import Layout from "../layouts/Layout.astro";
import Nav from "../components/nav.astro";
---

<Layout title="Website Project - Johnny Kamnang">
  <Nav />

  <section class="section-container min-h-screen pt-28 md:pt-36">
    <div class="container mx-auto">
      <a href="/#projects" class="inline-flex items-center gap-2 text-sm text-accent hover:text-maintext transition-colors mb-10">
        <Icon name="mdi:arrow-left" class="w-5 h-5" />
        Back to projects
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 lg:gap-16 items-center">
        <div class="relative order-2 lg:order-1 reveal-content" style="animation-delay: 200ms;">
          <div class="absolute inset-8 bg-accent/20 blur-3xl rounded-full"></div>
          <div class="relative rounded-2xl overflow-hidden border border-accent/20 bg-background/70 shadow-2xl">
            <div class="flex items-center gap-2 border-b border-accent/10 bg-accent/5 px-4 py-3">
              <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
              <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
            </div>
            <img
              src="/astro-01.webp"
              alt="Website project preview"
              class="w-full aspect-video object-cover"
            />
          </div>
        </div>

        <div class="space-y-8 order-1 lg:order-2 reveal-content" style="animation-delay: 100ms;">
          <div class="space-y-4">
            <span class="text-accent text-xs uppercase tracking-widest font-bold">Published Website</span>
            <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight">
              Awesome Website
            </h1>
            <p class="text-subtext font-body text-base md:text-lg leading-relaxed max-w-2xl">
              A modern web project focused on performance, responsive presentation, and a clear technical portfolio experience built with Astro and Tailwind.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:web" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Platform</h2>
              <p class="text-subtext text-sm">Responsive web</p>
            </div>
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:lightning-bolt" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Stack</h2>
              <p class="text-subtext text-sm">Astro, Tailwind</p>
            </div>
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:magnify" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Focus</h2>
              <p class="text-subtext text-sm">SEO and speed</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8 reveal-content" style="animation-delay: 350ms;">
        <section class="space-y-4">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext">
            <span class="text-accent">/</span> Challenge
          </h2>
          <p class="text-subtext leading-relaxed">
            The goal is to keep the site lightweight while presenting project information, identity, and calls to action without adding friction to the browsing experience.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext">
            <span class="text-accent">/</span> Result
          </h2>
          <p class="text-subtext leading-relaxed">
            The page structure stays easy to extend, preserves the existing visual language, and gives each project a dedicated space beyond the one-page portfolio.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
