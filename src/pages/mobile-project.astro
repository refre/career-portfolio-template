---
import { Icon } from 'astro-icon/components';
import Layout from "../layouts/Layout.astro";
import Nav from "../components/nav.astro";

const mobileApps = [
  {
    title: "MusicBoss Africa",
    description: "Music trivia on african music, goodies inside more than 15.000 download.",
    image: "/musicboss-africa.png",
    tech: ["Xamarin", "UWP", "REST API"],
  },
  {
    title: "Punchlines MJJ",
    description: "Trivia on Michael Jackson, music and lyrics. goodies inside more than 25.000 download.",
    image: "/musicboss-mjj.png",
    tech: ["Xamarin", "UWP", "REST API"],
  },
  {
    title: "MusicBoss Francais",
    description: "Music trivia on french music, goodies inside more than 35.000 download. .",
    image: "/musicboss-francais.png",
    tech: ["Xamarin", "UWP", "REST API"],
  },
];
---

<Layout title="Mobile Project - Johnny Kamnang">
  <Nav />

  <section class="section-container min-h-screen pt-28 md:pt-36">
    <div class="container mx-auto">
      <a href="/#projects" class="inline-flex items-center gap-2 text-sm text-accent hover:text-maintext transition-colors mb-10">
        <Icon name="mdi:arrow-left" class="w-5 h-5" />
        Back to projects
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-16 items-center">
        <div class="space-y-8 reveal-content" style="animation-delay: 100ms;">
          <div class="space-y-4">
            <span class="text-accent text-xs uppercase tracking-widest font-bold">Mobile Application</span>
            <h1 class="text-4xl md:text-6xl font-heading font-bold text-maintext tracking-tight">
              Mobile App
            </h1>
            <p class="text-subtext font-body text-base md:text-lg leading-relaxed max-w-2xl">
              A performant mobile experience designed for iOS and Android, with clear flows, reliable API integration, and a polished interface that stays easy to use on small screens.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:cellphone" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Platform</h2>
              <p class="text-subtext text-sm">iOS and Android</p>
            </div>
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:code-braces" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Stack</h2>
              <p class="text-subtext text-sm">Xamarin, MAUI, REST API</p>
            </div>
            <div class="bg-accent/5 border border-accent/10 rounded-2xl p-5">
              <Icon name="mdi:rocket-launch" class="w-7 h-7 text-accent mb-4" />
              <h2 class="text-maintext font-heading font-bold mb-1">Focus</h2>
              <p class="text-subtext text-sm">Fast, clean workflows</p>
            </div>
          </div>
        </div>

        <div class="relative reveal-content" style="animation-delay: 250ms;">
          <div class="absolute inset-8 bg-accent/20 blur-3xl rounded-full"></div>
          <div class="relative mx-auto w-full max-w-sm aspect-[9/16] rounded-[2rem] border border-accent/20 bg-background/70 p-3 shadow-2xl">
            <div class="h-full rounded-[1.5rem] overflow-hidden bg-accent/5 border border-white/10">
              <img
                src="/mobile.png"
                alt="Mobile project "
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-8 reveal-content" style="animation-delay: 350ms;">
        <section class="space-y-4">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext">
            <span class="text-accent">/</span> Challenge
          </h2>
          <p class="text-subtext leading-relaxed">
            The project centers on turning a compact mobile flow into something dependable: quick loading, readable information hierarchy, and touch-friendly actions across device sizes.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext">
            <span class="text-accent">/</span> Result
          </h2>
          <p class="text-subtext leading-relaxed">
            The final direction emphasizes reusable UI patterns, stable navigation, and API-driven content that can scale without making the interface feel heavy.
          </p>
        </section>
      </div>

      <section class="mt-20 reveal-content" style="animation-delay: 450ms;">
        <div class="mb-10">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-maintext mb-2">
            <span class="text-accent">/</span> Mobile Applications
          </h2>
          <p class="text-subtext font-body text-sm max-w-md">
            Three mobile projects built around focused music experiences.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {mobileApps.map((app) => (
            <article class="group relative bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-500">
              <div class="aspect-video overflow-hidden relative bg-background/50">
                <div class="absolute inset-0 bg-accent/10 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>
                <img
                  src={app.image}
                  alt={`${app.title} screenshot`}
                  onerror="this.onerror=null;this.src='/placeholder.jpeg';"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                />
                <div class="absolute top-3 right-3 flex gap-2 z-20">
                  <div class="p-1.5 bg-background backdrop-blur-md rounded-lg border border-accent/10 text-maintext">
                    <Icon name="mdi:cellphone" class="w-4 h-4" />
                  </div>
                </div>
              </div>

              <div class="p-6 space-y-4">
                <div>
                  <span class="text-accent text-[10px] uppercase tracking-widest font-bold">Mobile App</span>
                  <h3 class="text-xl font-heading font-bold text-maintext mt-1">{app.title}</h3>
                </div>

                <p class="text-subtext text-sm font-body line-clamp-3">
                  {app.description}
                </p>

                <div class="flex flex-wrap gap-2 pt-2">
                  {app.tech.map((tech) => (
                    <span class="rounded-md text-[10px] px-2 md:px-4 py-1 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>
</Layout>
